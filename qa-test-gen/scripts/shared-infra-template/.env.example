# Copy to .env on the host (chmod 600). Generate secrets with `openssl rand -base64 24`.
KEYCLOAK_ADMIN_USER=superadmin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
KEYCLOAK_DB_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_24
AAQUA_DB_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_24
# KC_HOSTNAME: bare hostname for Keycloak's KC_HOSTNAME — NOT a URL, no scheme, no port.
# Keycloak adds the scheme itself based on X-Forwarded-Proto from shared-nginx.
KC_HOSTNAME=aaqua.aaseya.com
# KC_HOSTNAME_PORT: non-default public port (omit / leave 8443 if you serve on standard 443).
KC_HOSTNAME_PORT=8443
# KC_PUBLIC_BASE_URL: full URL with scheme (and port if non-standard) — used by
# render-realm.sh to substitute rootUrl / baseUrl / redirectUris in the realm template.
KC_PUBLIC_BASE_URL=https://aaqua.aaseya.com:8443
