server {
    listen 80;
    server_name _;

    # Static React bundle (built in stage 1 of the Dockerfile, copied here).
    root /var/www/aaqua;
    index index.html;

    add_header X-Frame-Options       "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff"   always;
    add_header Referrer-Policy        "strict-origin-when-cross-origin" always;

    gzip            on;
    gzip_min_length 1024;
    gzip_types      text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript;

    # /api/convert and /api/run-tests accept ZIP uploads — keep this generous.
    client_max_body_size 50m;

    # SPA fallback — every unmatched path serves index.html.
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Express backend on the loopback inside the same container.
    location /api/ {
        proxy_pass         http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    # LLM proxy — replaces the Vite dev proxy. The Authorization header is
    # injected from the Docker secret (rendered into this file by envsubst at
    # container start), so the browser bundle never holds the real key.
    location /llm-api/ {
        proxy_pass            https://llm.lab.aaseya.com/;
        proxy_http_version    1.1;
        proxy_ssl_server_name on;
        proxy_set_header      Host          llm.lab.aaseya.com;
        proxy_set_header      Authorization "Bearer ${LLM_API_KEY}";
        proxy_set_header      Content-Type  "application/json";
        proxy_read_timeout    120s;
    }
}
