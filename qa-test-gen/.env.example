# AAQUA environment template — copy to `.env` and fill in real values.
# Both the Vite frontend (`import.meta.env.VITE_*`) and the Express server
# (`process.env.*` after dotenv) read from this file.

# ─── LLM (Aaseya AI gateway) ─────────────────────────────
VITE_LLM_API_KEY=
VITE_LLM_ENDPOINT=https://llm.lab.aaseya.com/v1
VITE_LLM_MODEL=gpt-oss-20b

# ─── PostgreSQL (local dev — `docker-compose.security.yml`) ──────────────
DATABASE_URL=postgresql://aaqua:aaqua@localhost:5433/aaqua_security
DB_LOGGING=false

# ─── OWASP ZAP ───────────────────────────────────────────
ZAP_API_URL=http://localhost:8080
ZAP_API_KEY=

# ─── Keycloak (IAM) ──────────────────────────────────────
# The bootstrap superadmin used to create temporary passwords for the seed
# admins (Sanjay Jain, Kavita Chonkar) — do NOT distribute.
KEYCLOAK_ADMIN_USER=superadmin
KEYCLOAK_ADMIN_PASSWORD=
# Password for the `keycloak_user` Postgres role (used by Keycloak to access
# the `keycloak` schema). Must match secrets/db_password rotation cadence.
KEYCLOAK_DB_PASSWORD=
# Backend uses this to discover the JWKS endpoint and validate `iss`.
# In production, set to the public Keycloak URL (e.g. https://auth.aaseya.com/realms/aaseya-platform).
KEYCLOAK_REALM_URL=http://localhost:8082/realms/aaseya-platform
# Backend enforces this as `aud` (or `azp`) on incoming tokens.
KEYCLOAK_AUDIENCE=aaqua-frontend
# Frontend OIDC config (read by Vite at build time — also baked into the SPA).
VITE_KEYCLOAK_URL=http://localhost:8082
VITE_KEYCLOAK_REALM=aaseya-platform
VITE_KEYCLOAK_CLIENT_ID=aaqua-frontend

# ─── Production-only Keycloak settings (used by docker-compose.yml) ──────
# Public hostname Keycloak issues tokens under (token `iss` claim).
# KC_HOSTNAME=https://auth.aaseya.com
# Set to "true" once HTTPS is terminated upstream and you trust the proxy.
# KC_HOSTNAME_STRICT=true
# KC_HOSTNAME_STRICT_HTTPS=true
# KC_PROXY=edge

# ─── Jira integration (optional) ─────────────────────────
JIRA_ENABLED=false
JIRA_URL=
JIRA_EMAIL=
JIRA_TOKEN=
JIRA_PROJECT_KEY=

# ─── Security controls ───────────────────────────────────
# Allow ZAP to scan private/internal IPs. Off by default; turn on only for
# trusted internal targets.
ALLOW_PRIVATE_SCAN=false
