# AAQUA environment template — copy to `.env` and fill in real values.
# Both the Vite frontend (`import.meta.env.VITE_*`) and the Express server
# (`process.env.*` after dotenv) read from this file.

# ─── LLM (Aaseya AI gateway) ─────────────────────────────
VITE_LLM_API_KEY=
VITE_LLM_ENDPOINT=https://llm.lab.aaseya.com/v1
VITE_LLM_MODEL=gpt-oss-20b

# ─── PostgreSQL ──────────────────────────────────────────
# Local dev: single DATABASE_URL is fine (matches `docker-compose.security.yml`).
DATABASE_URL=postgresql://aaqua:aaqua@localhost:5433/aaqua_security
DB_LOGGING=false
# Deployed (docker-compose.yml) path: `server/db.js` resolves the URL from the
# four DB_* env vars + a file-mounted password secret. The compose file sets
# DB_HOST=shared-postgres, DB_PORT=5432, DB_USER=aaqua_app, DB_NAME=aaqua_security
# and mounts the password at /run/secrets/db_password (Docker Compose v2 secret).
# Override DB_PASSWORD_FILE only if you mount the secret somewhere else.
# DB_HOST=
# DB_PORT=5432
# DB_USER=aaqua_app
# DB_NAME=aaqua_security
# DB_PASSWORD_FILE=/run/secrets/db_password

# ─── OWASP ZAP ───────────────────────────────────────────
ZAP_API_URL=http://localhost:8080
ZAP_API_KEY=

# ─── Keycloak (IAM) ──────────────────────────────────────
# The bootstrap superadmin used to create temporary passwords for the seed
# admins (Sanjay Jain, Kavita Chonkar) — do NOT distribute.
KEYCLOAK_ADMIN_USER=superadmin
KEYCLOAK_ADMIN_PASSWORD=
# Password for the `keycloak_user` Postgres role (used by Keycloak to access
# the `keycloak` schema). Must match secrets/db_password rotation cadence.
KEYCLOAK_DB_PASSWORD=
# Backend uses this to validate token `iss` claim (strict string equality).
# Set to the PUBLIC Keycloak URL — that's what Keycloak puts in the `iss` claim.
# In production, e.g. https://auth.aaseya.com/realms/aaseya-platform.
KEYCLOAK_REALM_URL=http://localhost:8082/realms/aaseya-platform
# Optional: backend JWKS-fetch URL. Defaults to ${KEYCLOAK_REALM_URL}/protocol/openid-connect/certs.
# Override when the public URL uses a self-signed TLS cert the backend can't validate —
# point at the docker-internal Keycloak instead. Example:
#   KEYCLOAK_JWKS_URL=http://shared-keycloak:8080/auth/realms/aaseya-platform/protocol/openid-connect/certs
# Issuer matching still uses KEYCLOAK_REALM_URL (the public one).
# KEYCLOAK_JWKS_URL=
# Backend enforces this as `aud` (or `azp`) on incoming tokens.
KEYCLOAK_AUDIENCE=aaqua-frontend
# Frontend OIDC config (read by Vite at build time — also baked into the SPA).
VITE_KEYCLOAK_URL=http://localhost:8082
VITE_KEYCLOAK_REALM=aaseya-platform
VITE_KEYCLOAK_CLIENT_ID=aaqua-frontend

# ─── Production-only Keycloak settings (used by docker-compose.yml) ──────
# Public hostname Keycloak issues tokens under (token `iss` claim).
# Must be a BARE hostname — no scheme, no port. Non-default port goes in KC_HOSTNAME_PORT.
# KC_HOSTNAME=auth.aaseya.com
# KC_HOSTNAME_PORT=8443
# Strict frontchannel: rejects requests whose Host header doesn't match KC_HOSTNAME.
# KC_HOSTNAME_STRICT=true
# Lenient backchannel: lets the backend reach Keycloak via the docker-internal hostname.
# KC_HOSTNAME_STRICT_BACKCHANNEL=false
# KC_HOSTNAME_STRICT_HTTPS=true
# KC_PROXY_HEADERS=xforwarded  (replaces deprecated KC_PROXY=edge, removed in Keycloak 26+)

# ─── Jira integration (optional) ─────────────────────────
JIRA_ENABLED=false
JIRA_URL=
JIRA_EMAIL=
JIRA_TOKEN=
JIRA_PROJECT_KEY=

# ─── Security controls ───────────────────────────────────
# Allow ZAP to scan private/internal IPs. Off by default; turn on only for
# trusted internal targets.
ALLOW_PRIVATE_SCAN=false
